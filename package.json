{
  "name": "hono.dev",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build",
    "preview": "wrangler pages dev",
    "deploy": "$npm_execpath run build && wrangler pages deploy",
    "format": "yarn prettier --check ./docs ./examples index.md",
    "format:fix": "yarn prettier --check --write ./docs ./examples index.md"
  },
  "repository": "git@github.com:honojs/website.git",
  "author": "Yusuke Wada <yusuke@kamawada.com>",
  "private": true,
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "@hono/vite-cloudflare-pages": "^0.4.1",
    "@hono/vite-dev-server": "^0.12.1",
    "@mdx-js/rollup": "^3.0.1",
    "prettier": "^3.3.2",
    "remark-gfm": "^4.0.0",
    "vite": "^5.2.12",
    "wrangler": "^3.57.2"
  },
  "dependencies": {
    "hono": "^4.4.7",
    "honox": "^0.1.23"
  }
}
